# syntax=docker/dockerfile:1
# Warden Cell - claudecodetricks
# Generated by: warden init / warden build
# Regenerate with: warden build --force

FROM debian:bookworm

# === Base Setup ===
ENV DEBIAN_FRONTEND=noninteractive

# === All System Packages (single apt layer) ===
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    coreutils \
    curl \
    emacs-nox \
    git \
    gnupg \
    make \
    openssh-client \
    procps \
    sudo \
    unzip \
    xclip \
    xvfb \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# === Mirror Mode User Setup ===
RUN groupadd -g 20 travis 2>/dev/null || true && \
    useradd -m -u 503 -g 20 -s /bin/bash travis && \
    echo 'travis ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers && \
    mkdir -p /Users && ln -sf /home/travis /Users/travis

# === Environment Variables ===
ENV WARDEN_AI_AGENT=CLAUDE-CODE
ENV WARDEN_CLIPBOARD_HOST=host.docker.internal
ENV WARDEN_CLIPBOARD_PORT=8377
ENV NODE_VERSION=20
ENV NPM_CONFIG_PREFIX=/root/.npm-global
ENV PATH=/root/.npm-global/bin:$PATH
ENV WARDEN_GRPC_HOST=host.docker.internal
ENV WARDEN_GRPC_PORT=8378
ENV DISPLAY=:99

# === Project Requirements: Clipboard Scripts ===
RUN echo '' | base64 -d | /bin/bash -e
RUN echo '' | base64 -d | /bin/bash -e

# === Project Requirements: Emacs editor config ===
RUN echo "# Emacs as default editor" >> ~/.bashrc
RUN echo "export EDITOR=emacs" >> ~/.bashrc
RUN echo "export VISUAL=emacs" >> ~/.bashrc

# === Project Requirements: Node.js ===
RUN echo '' | base64 -d | /bin/bash -e
RUN npm install -g npm@latest && npm install -g yarn pnpm

# === Project Requirements: Node.js bashrc config ===
RUN echo "# Node.js 20 LTS" >> ~/.bashrc
RUN echo "export NPM_CONFIG_PREFIX=/root/.npm-global" >> ~/.bashrc
RUN echo "export PATH=/root/.npm-global/bin:\$PATH" >> ~/.bashrc

# === Project Requirements: Warden Prompt (root + system) ===
RUN echo '' | base64 -d | /bin/bash -e
RUN echo '' | base64 -d | /bin/bash -e

# === Warden Cell Server ===
COPY .warden/warden-cellserver /usr/local/bin/warden-cellserver
RUN chmod +x /usr/local/bin/warden-cellserver

# === Switch to non-root user ===
USER travis

# === Warden Prompt (mirror-mode user) ===
RUN echo '' | base64 -d | /bin/bash -e

# === Claude Code ===
RUN curl -fsSL https://claude.ai/install.sh | bash
RUN echo "export PATH=\"\$HOME/.local/bin:\$PATH\"" >> ~/.bashrc
RUN echo "alias yolo='IS_SANDBOX=1 claude --dangerously-skip-permissions --continue'" >> ~/.bashrc
RUN echo "alias yolo-new='IS_SANDBOX=1 claude --dangerously-skip-permissions'" >> ~/.bashrc

# Auto-start warden-cellserver daemon on shell entry
RUN echo '# Start warden-cellserver daemon if not running' >> ~/.bashrc && \
    echo 'if ! pgrep -f "warden-cellserver daemon" > /dev/null 2>&1; then' >> ~/.bashrc && \
    echo '  nohup warden-cellserver daemon > /tmp/warden-cellserver.log 2>&1 &' >> ~/.bashrc && \
    echo '  disown' >> ~/.bashrc && \
    echo 'fi' >> ~/.bashrc

WORKDIR /home/travis/workspace/x85446/claudecodetricks
CMD ["bash"]